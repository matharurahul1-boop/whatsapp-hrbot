# ─── Supabase ────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── Claude AI ───────────────────────────────────────────────────────────────
# Found in: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your-key

# ─── WhatsApp Cloud API ───────────────────────────────────────────────────────
# Found in: developers.facebook.com → Your App → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=choose-a-random-verify-token
# Your Facebook App Secret — found at developers.facebook.com > Your App > Settings > Basic
# This is DIFFERENT from the verify token above. Used for HMAC-SHA256 signature verification.
WHATSAPP_APP_SECRET=your-facebook-app-secret
WHATSAPP_BUSINESS_ACCOUNT_ID=your-waba-id

# ─── n8n ─────────────────────────────────────────────────────────────────────
N8N_BASE_URL=https://your-n8n-instance.com
N8N_API_KEY=your-n8n-api-key
N8N_WEBHOOK_SECRET=your-webhook-secret
# When set, inbound WA messages are forwarded here instead of running the agent locally.
# Point this to your n8n wa-inbound webhook URL, e.g.:
#   N8N_WEBHOOK_URL=https://your-n8n.com/webhook/wa-inbound
N8N_WEBHOOK_URL=

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_SECRET=your-random-app-secret-min-32-chars

# ─── Policy Bot (Groq) ───────────────────────────────────────────────────────
# Found in: console.groq.com → API Keys
GROQ_API_KEY=your-groq-api-key
# Shared secret for internal server-to-server calls (webhook → policy/ask)
POLICY_SECRET=your-random-policy-secret

# ─── Escalation cron ─────────────────────────────────────────────────────────
ESCALATION_SECRET=your-random-escalation-secret
