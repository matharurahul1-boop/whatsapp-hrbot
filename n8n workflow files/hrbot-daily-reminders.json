              "value": "=Bearer {{ $env.SUPABASE_SERVICE_ROLE }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={ \"workflow_name\": \"daily-reminders\", \"status\": \"success\", \"payload\": { \"sent\": {{ $node['Build Messages'].data.length }}, \"timestamp\": \"{{ new Date().toISOString() }}\" } }"
      },
      "name": "Log Result",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        1580,
        300
      ],
      "id": "log-result"
    }
  ],
