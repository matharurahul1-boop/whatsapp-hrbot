    {
      "parameters": {
        "assignments": {
          "assignments": [
            { "id": "r05", "name": "phone",     "value": "={{ $('Set Intent').item.json.phone }}", "type": "string" },
            { "id": "r06", "name": "replyText", "value": "=📋 *Your Tasks*\n\n{{ $json.map((t,i)=>`${i+1}. ${t.status==='in_progress'?'🔄':'⏳'} *${t.title}*${t.deadline?' | '+new Date(t.deadline).toLocaleDateString('en-IN'):''}`).join('\\n') }}\n\nWhat else can I help you with?", "type": "string" }
          ]
