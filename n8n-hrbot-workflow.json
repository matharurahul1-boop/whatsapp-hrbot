      "parameters": {
        "assignments": {
          "assignments": [
            { "id": "r01", "name": "phone",     "value": "={{ $('Set Intent').item.json.phone }}",    "type": "string" },
            { "id": "r02", "name": "replyText", "value": "=✅ Checked in at *{{ new Date().toLocaleTimeString('en-IN',{timeZone:'Asia/Kolkata',hour:'2-digit',minute:'2-digit'}) }}*. Have a great day!", "type": "string" }
          ]
        },
        "options": {}
      },
      "id": "node-009",
      "name": "Reply CheckIn",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [1780, 60]
