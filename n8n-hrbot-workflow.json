{
  "name": "HRBot WhatsApp AI Workflow",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "whatsapp-webhook",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "node-001",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [0, 300]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            { "id": "f01", "name": "phone",     "value": "={{ $json.body.entry[0].changes[0].value.messages[0].from }}", "type": "string" },
            { "id": "f02", "name": "text",      "value": "={{ $json.body.entry[0].changes[0].value.messages[0].text.body }}", "type": "string" },
            { "id": "f03", "name": "messageId", "value": "={{ $json.body.entry[0].changes[0].value.messages[0].id }}", "type": "string" }
          ]
        },
        "options": {}
      },
      "id": "node-002",
      "name": "Extract Message",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [220, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/users?wa_number=eq.{{ $json.phone }}&select=id,full_name,role,organization_id&limit=1",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey",        "value": "={{ $env.SUPABASE_KEY }}" },
            { "name": "Authorization", "value": "=Bearer {{ $env.SUPABASE_KEY }}" }
          ]
        },
        "options": {}
      },
      "id": "node-003",
      "name": "Lookup User",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [440, 300]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            { "id": "f04", "name": "phone",  "value": "={{ $('Extract Message').item.json.phone }}", "type": "string" },
            { "id": "f05", "name": "text",   "value": "={{ $('Extract Message').item.json.text }}",  "type": "string" },
            { "id": "f06", "name": "userId", "value": "={{ $json[0].id }}",              "type": "string" },
            { "id": "f07", "name": "userName","value": "={{ $json[0].full_name }}",       "type": "string" },
            { "id": "f08", "name": "userRole","value": "={{ $json[0].role }}",            "type": "string" },
            { "id": "f09", "name": "orgId",  "value": "={{ $json[0].organization_id }}", "type": "string" }
          ]
        },
        "options": {}
      },
      "id": "node-004",
      "name": "Merge Context",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [660, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "x-api-key",          "value": "={{ $env.ANTHROPIC_API_KEY }}" },
            { "name": "anthropic-version",  "value": "2023-06-01" },
            { "name": "content-type",       "value": "application/json" }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "body": "={ \"model\":\"claude-3-haiku-20240307\",\"max_tokens\":100,\"system\":\"Classify into ONE intent: attendance_checkin | attendance_checkout | list_tasks | apply_leave | leave_balance | help | general_chat. Reply ONLY valid JSON: {\\\"intent\\\":\\\"<name>\\\"}\",\"messages\":[{\"role\":\"user\",\"content\":\"{{ $json.text }}\"}] }",
        "options": {}
      },
      "id": "node-005",
      "name": "AI Classify Intent",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [880, 300]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            { "id": "f10", "name": "phone",    "value": "={{ $('Merge Context').item.json.phone }}",    "type": "string" },
            { "id": "f11", "name": "text",     "value": "={{ $('Merge Context').item.json.text }}",     "type": "string" },
            { "id": "f12", "name": "userId",   "value": "={{ $('Merge Context').item.json.userId }}",   "type": "string" },
            { "id": "f13", "name": "userName", "value": "={{ $('Merge Context').item.json.userName }}", "type": "string" },
            { "id": "f14", "name": "userRole", "value": "={{ $('Merge Context').item.json.userRole }}", "type": "string" },
            { "id": "f15", "name": "orgId",    "value": "={{ $('Merge Context').item.json.orgId }}",    "type": "string" },
            { "id": "f16", "name": "intent",   "value": "={{ JSON.parse($json.content[0].text).intent }}", "type": "string" }
          ]
        },
        "options": {}
      },
      "id": "node-006",
      "name": "Set Intent",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [1100, 300]
    },
    {
      "parameters": {
        "rules": {
          "rules": [
            { "outputKey": "checkin",       "conditions": { "options": { "caseSensitive": false }, "conditions": [{ "leftValue": "={{ $json.intent }}", "rightValue": "attendance_checkin",  "operator": { "type": "string", "operation": "equals" } }] } },
            { "outputKey": "checkout",      "conditions": { "options": { "caseSensitive": false }, "conditions": [{ "leftValue": "={{ $json.intent }}", "rightValue": "attendance_checkout", "operator": { "type": "string", "operation": "equals" } }] } },
            { "outputKey": "tasks",         "conditions": { "options": { "caseSensitive": false }, "conditions": [{ "leftValue": "={{ $json.intent }}", "rightValue": "list_tasks",          "operator": { "type": "string", "operation": "equals" } }] } },
            { "outputKey": "apply_leave",   "conditions": { "options": { "caseSensitive": false }, "conditions": [{ "leftValue": "={{ $json.intent }}", "rightValue": "apply_leave",         "operator": { "type": "string", "operation": "equals" } }] } },
            { "outputKey": "leave_balance", "conditions": { "options": { "caseSensitive": false }, "conditions": [{ "leftValue": "={{ $json.intent }}", "rightValue": "leave_balance",       "operator": { "type": "string", "operation": "equals" } }] } },
            { "outputKey": "help",          "conditions": { "options": { "caseSensitive": false }, "conditions": [{ "leftValue": "={{ $json.intent }}", "rightValue": "help",                "operator": { "type": "string", "operation": "equals" } }] } }
          ]
        },
        "fallbackOutput": "none",
        "options": {}
      },
      "id": "node-007",
      "name": "Intent Router",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3.2,
      "position": [1320, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/attendance_records",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey",        "value": "={{ $env.SUPABASE_KEY }}" },
            { "name": "Authorization", "value": "=Bearer {{ $env.SUPABASE_KEY }}" },
            { "name": "Content-Type",  "value": "application/json" },
            { "name": "Prefer",        "value": "return=representation" }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "body": "={ \"organization_id\":\"{{ $json.orgId }}\",\"employee_id\":\"{{ $json.userId }}\",\"date\":\"{{ new Date().toLocaleDateString('en-CA',{timeZone:'Asia/Kolkata'}) }}\",\"check_in_time\":\"{{ new Date().toISOString() }}\",\"status\":\"present\" }",
        "options": {}
      },
