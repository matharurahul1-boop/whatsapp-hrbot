            { "name": "organization_id", "value": "=eq.{{ $('Build Context').item.json.org_id }}" },
            { "name": "select",          "value": "id,title,deadline,priority,status,assignee:users!tasks_assignee_id_fkey(full_name)" },
            { "name": "order",           "value": "deadline.asc.nullslast" },
            { "name": "limit",           "value": "20" }
